# Port the service listens on (host side)
SERVICE_PORT=8001

# CORS allowed origins — comma-separated list, or * for all
# Example for production: ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=*

# Path to the TFLite model inside the container (do not change unless you know what you're doing)
MODEL_PATH=/app/mobilefacenet.tflite
